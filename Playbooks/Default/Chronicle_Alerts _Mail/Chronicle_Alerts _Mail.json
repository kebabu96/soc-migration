n Rule</td>\\n            <td style=\\\"padding:10px; border:1px solid #ddd;\\\">[Event.detection_1_ruleName]</td>\\n        </tr>\\n\\n    </table>\\n\\n    <div style=\\\"margin-top:25px;\\\">\\n        <h3 style=\\\"color:#4285f4;\\\">\ud83e\udd16 Gemini AI Summary</h3>\\n        <div style=\\\"background:#f8f9fa; padding:15px; border-left:4px solid #4285f4; border-radius:4px;\\\">\\n            [Siemplify_Create Gemini Case Summary_1.JsonResult| \\\"summary\\\"]\\n        </div>\\n    </div>\\n\\n    <div style=\\\"margin-top:25px; padding:15px; background:#fff3cd; border-left:4px solid #ffc107;\\\">\\n        <strong>Action Required:</strong><br>\\n        Please review the case in Google SecOps and take appropriate action based on the incident severity and investigation findings.\\n    </div>\\n\\n    <hr style=\\\"margin-top:30px;\\\">\\n\\n    <p style=\\\"font-size:12px; color:gray;\\\">\\n        This is an automated notification generated by Google SecOps SOAR.\\n    </p>\\n\\n</div>\\n\\n</body>\\n</html>\\n\",\"Reply-To Recipients\":\"\",\"Attachment Location\":\"GCP Bucket\",\"Send From\":\"SecOpsAlerts@ashleyfurniture.com\",\"Subject\":\"SecOps Alert\",\"Send to\":\"dreddy@ashleyfurniture.com\",\"CC\":\"\"}",
